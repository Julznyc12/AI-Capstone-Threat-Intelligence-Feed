        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"llama-3.3-70b-versatile\",\n  temperature: 0.2,\n\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a cybersecurity relevance scoring assistant. Compare a threat to an organization's technology stack and determine how relevant it is. Return only valid JSON. Do not use markdown.\\n\\nOnly match technologies if the threat directly targets, affects, exploits, or significantly relates to that technology.\\n\\nDo not match technologies based on vague or generic mentions.\\n\\nIf no technologies are clearly affected, set relevance_score between 0-30 and relevance_level to Low.\\n\\nIncrease relevance if:\\n- ransomware is involved\\n- remote code execution is involved\\n- privilege escalation is involved\\n- active exploitation is mentioned\\n- severity is Critical or High\\n- critical infrastructure is targeted\\n\\nPresence of valid IOCs increases operational relevance.\"\n    },\n\n    {\n      role: \"user\",\n\n      content:\n        \"Technology stack:\\n\" + $json.tech_stack +\n\n        \"\\n\\nThreat:\\n\" + $json.threat_context +\n\n        \"\\n\\nScore relevance from 0 to 100.\" +\n\n        \"\\nRules:\" +\n        \"\\n75-100 = High relevance\" +\n        \"\\n40-74 = Medium relevance\" +\n        \"\\n0-39 = Low relevance\" +\n\n        \"\\n\\nReturn ONLY valid JSON with exactly these keys:\" +\n        \"\\nrelevance_score, relevance_level, matched_technologies, reason\" +\n\n        \"\\n\\nExample:\" +\n        \"\\n{\\\"relevance_score\\\": 75, \\\"relevance_level\\\": \\\"High\\\", \\\"matched_technologies\\\": [\\\"Apache HTTP Server\\\"], \\\"reason\\\": \\\"The threat directly affects Apache, which is in the technology stack.\\\"}\"\n    }\n  ]\n}) }}",
        "options": {
          "timeout": 30000
        }
      },
