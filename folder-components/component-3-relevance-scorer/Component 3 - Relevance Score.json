    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let raw = $input.item.json.choices?.[0]?.message?.content || \"\";\n\nraw = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (error) {\n  parsed = {\n    relevance_score: 0,\n\n    relevance_level: \"Low\",\n\n    matched_technologies: [],\n\n    reason: \"Failed to parse model response. Raw output: \" + raw\n  };\n}\n\nreturn {\n  json: {\n    record_id: $(\"Edit Fields\").item.json.record_id,\n\n    relevance_score: Number(parsed.relevance_score) || 0,\n\n    relevance_level: parsed.relevance_level || \"Low\",\n\n    matched_tech: Array.isArray(parsed.matched_technologies)\n      ? parsed.matched_technologies.join(\", \")\n      : String(parsed.matched_technologies || \"none\"),\n\n    relevance_reason:\n      parsed.reason || \"No reason returned.\",\n\n    scored_at: new Date().toISOString(),\n\n    scored_by: \"Groq llama-3.3-70b-versatile\",\n\n    scored: true,\n\n    current_status: \"Scored\"\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
